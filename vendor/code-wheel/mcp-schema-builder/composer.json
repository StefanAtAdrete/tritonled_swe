{
    "name": "code-wheel/mcp-schema-builder",
    "description": "JSON Schema builder and validator for MCP tool definitions",
    "type": "library",
    "license": "MIT",
    "keywords": ["mcp", "model-context-protocol", "json-schema", "validation", "tools", "schema"],
    "authors": [
        {
            "name": "Code Wheel",
            "email": "mowens3@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "code-wheel/mcp-error-codes": "^1.2"
    },
    "suggest": {
        "code-wheel/mcp-error-codes": "Required for ValidationResult::toErrorBag() integration"
    },
    "autoload": {
        "psr-4": {
            "CodeWheel\\McpSchemaBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeWheel\\McpSchemaBuilder\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
