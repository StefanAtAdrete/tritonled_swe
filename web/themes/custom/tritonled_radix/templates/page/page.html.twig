{#
/**
 * @file
 * TritonLED page template.
 *
 * Navbar: sticky-top, Bootstrap offcanvas för mobil.
 * Desktop: collapse navbar-collapse (standard Bootstrap).
 * Mobil: offcanvas-start slide-in sidebar.
 */
#}
<div class="page">

  {# TOPBAR #}
  {% if page.topbar_left or page.topbar_right %}
  <div class="topbar bg-white border-bottom py-2">
    <div class="container d-flex align-items-center">
      {% if page.topbar_left %}
        <div class="me-auto">
          {{ page.topbar_left }}
        </div>
      {% endif %}
      {% if page.topbar_right %}
        <div class="ms-auto">
          {{ page.topbar_right }}
        </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

  {# NAVBAR — sticky, vit, flat #}
  <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top" data-bs-theme="light">
    <div class="container">

      {# Branding #}
      {% if page.navbar_branding %}
        {{ page.navbar_branding }}
      {% endif %}

      {# Mobil: offcanvas toggler #}
      <button class="navbar-toggler border-0" type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#navbarOffcanvas"
        aria-controls="navbarOffcanvas"
        aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      {# Desktop: collapse meny #}
      <div class="collapse navbar-collapse">
        {% if page.navbar_left %}
          {{ page.navbar_left }}
        {% endif %}
        {% if page.navbar_left_2 %}
          {{ page.navbar_left_2 }}
        {% endif %}
        {% if page.navbar_left_3 %}
          <div class="ms-auto">
            {{ page.navbar_left_3 }}
          </div>
        {% endif %}
        {% if page.navbar_right %}
          <div class="ms-auto w-auto d-flex align-items-center gap-3">
            {{ page.navbar_right }}
          </div>
        {% endif %}
      </div>

    </div>
  </nav>

  {# MOBIL: Offcanvas sidebar #}
  <div class="offcanvas offcanvas-start" tabindex="-1" id="navbarOffcanvas" aria-labelledby="navbarOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
      <span class="offcanvas-title fw-bold" id="navbarOffcanvasLabel">TritonLED</span>
      {% if page.navbar_left_3 %}
        <div class="ms-auto me-2">
          {{ page.navbar_left_3 }}
        </div>
      {% endif %}
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
      {% if page.navbar_left %}
        {{ page.navbar_left }}
      {% endif %}
      {% if page.navbar_left_2 %}
        {{ page.navbar_left_2 }}
      {% endif %}
      {% if page.navbar_right %}
        <hr>
        {{ page.navbar_right }}
      {% endif %}
      {% if page.topbar_right %}
        <hr>
        <div class="d-flex align-items-center gap-3">
          {{ page.topbar_right }}
        </div>
      {% endif %}
    </div>
  </div>

  {# PAGE CONTENT #}
  {% include 'radix:page-content' with {
    page_content_container_type: 'fluid',
    page_main_utility_classes: ['p-0'],
  } %}

  {# FOOTER #}
  {% include 'radix:page-footer' %}

</div>
