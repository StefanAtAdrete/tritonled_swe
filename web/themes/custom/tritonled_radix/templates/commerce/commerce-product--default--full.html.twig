{#
/**
 * @file
 * Theme override for Commerce Product - Default (Full view mode)
 *
 * Available variables:
 * - attributes: HTML attributes for the wrapper.
 * - product: The product entity.
 * - product_id: The product ID.
 * - product_type: The product type (bundle).
 * - url: Direct URL of the current product.
 * - title: The product title.
 * - content: All product fields.
 *
 * IMPORTANT: Do NOT override individual field templates to preserve Commerce AJAX.
 * Use {{ content.field_name }} to render fields and maintain AJAX functionality.
 *
 * Bootstrap classes are used for spacing - edit these for design adjustments:
 * - mb-3, mb-4, mb-5: margin-bottom (3=1rem, 4=1.5rem, 5=3rem)
 * - mt-3, mt-4: margin-top
 * - p-3, p-4: padding
 * - col-md-7, col-md-5: grid columns (7+5=12, adjustable)
 */
#}
<div{{ attributes.addClass('product-page', 'product--default', 'mb-5') }}>
  <div class="container">
    <div class="row">
      
      {# LEFT COLUMN - Product Images (60% width on desktop) #}
      <div class="col-12 col-md-7 mb-4 mb-md-0">
        <div class="product-images">
          {# Primary product images #}
          {{ content.field_images }}
          
          {# Additional media (videos, etc) #}
          {{ content.field_product_media }}
        </div>
      </div>

      {# RIGHT COLUMN - Product Information (40% width on desktop) #}
      <div class="col-12 col-md-5">
        <div class="product-info">
          
          {# Series Badge #}
          {% if content.field_series %}
            <div class="product-series mb-2">
              <span class="badge bg-secondary">{{ content.field_series }}</span>
            </div>
          {% endif %}

          {# Product Title #}
          <h1 class="product-title mb-3">{{ title }}</h1>

          {# Short Description #}
          {% if content.field_short_description %}
            <div class="product-short-description text-muted mb-3">
              {{ content.field_short_description }}
            </div>
          {% endif %}

          {# Product Description (Body) #}
          {% if content.body %}
            <div class="product-description mb-4">
              {{ content.body }}
            </div>
          {% endif %}

          {# Brand/Manufacturer #}
          {% if content.field_brand %}
            <div class="product-brand mb-3">
              {{ content.field_brand }}
            </div>
          {% endif %}

          {# Product Variations - CRITICAL for AJAX #}
          <div class="product-variations mb-4">
            {{ content.variations }}
          </div>

          {# Call to Action Buttons #}
          <div class="product-actions mb-3">
            <button class="btn btn-primary btn-lg w-100 mb-2">
              Request Quote
            </button>
            {% if content.field_datasheet %}
              <div class="datasheet-link">
                {{ content.field_datasheet }}
              </div>
            {% endif %}
          </div>

          {# Volume Pricing Message #}
          <div class="volume-pricing-notice text-muted small text-center mb-3">
            Volume Pricing Available
          </div>

          {# Free Shipping Message #}
          <div class="shipping-notice text-muted small text-center">
            Free shipping on orders over $5,000
          </div>

        </div>
      </div>

    </div>

    {# Additional Features Section (Below Images) #}
    {% if content.field_features %}
      <div class="row mt-5">
        <div class="col-12">
          <div class="product-features">
            <h2 class="h4 mb-3">Key Features</h2>
            {{ content.field_features }}
          </div>
        </div>
      </div>
    {% endif %}

  </div>
</div>
