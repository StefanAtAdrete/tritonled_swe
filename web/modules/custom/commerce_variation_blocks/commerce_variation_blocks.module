<?php

/**
 * @file
 * Commerce Variation Blocks.
 *
 * Exposes all Commerce product variation view modes as pseudo-fields on the
 * product entity. This allows each variation view mode to be placed as an
 * independent block in Layout Builder on the product display.
 *
 * How it works:
 * 1. hook_entity_extra_field_info() - Discovers all active custom view modes
 *    on commerce_product_variation and declares a pseudo-field for each one
 *    on commerce_product.
 *
 * 2. hook_entity_view() - Renders the current variation using the
 *    corresponding view mode and injects it into the product build array.
 *    A unique CSS class is added to each container so that the EventSubscriber
 *    can target it via ReplaceCommand on AJAX variation change.
 *
 * 3. VariationAjaxChangeSubscriber - Listens to ProductEvents::PRODUCT_VARIATION_AJAX_CHANGE
 *    and sends ReplaceCommands for each pseudo-field container.
 *
 * Usage:
 * - Enable this module.
 * - Go to Commerce > Product types > Default > Manage display.
 * - In Layout Builder, find pseudo-fields named after your variation view modes
 *   (e.g. "Electrical", "Mechanical", "Certifications") under "Product fields".
 * - Place them anywhere in the layout.
 * - Configure each variation view mode's fields at:
 *   Commerce > Product variation types > Default > Manage display > [view mode tab]
 */

use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\commerce_product\Entity\ProductInterface;

/**
 * Implements hook_entity_extra_field_info().
 */
function commerce_variation_blocks_entity_extra_field_info() {
  $extra = [];

  $view_modes = \Drupal::service('entity_display.repository')
    ->getViewModes('commerce_product_variation');

  $skip = ['default', 'cart', 'card', 'summary'];

  foreach ($view_modes as $view_mode_id => $view_mode_info) {
    if (in_array($view_mode_id, $skip)) {
      continue;
    }

    $product_types = \Drupal::entityTypeManager()
      ->getStorage('commerce_product_type')
      ->loadMultiple();

    foreach ($product_types as $bundle_id => $product_type) {
      $extra['commerce_product'][$bundle_id]['display']['variation_block__' . $view_mode_id] = [
        'label' => $view_mode_info['label'],
        'description' => t('Variation fields rendered using the "@mode" view mode.', [
          '@mode' => $view_mode_info['label'],
        ]),
        'weight' => 10,
        'visible' => FALSE,
      ];
    }
  }

  return $extra;
}

/**
 * Implements hook_entity_view().
 *
 * Renders the current variation into each pseudo-field container.
 * Adds a unique CSS class for AJAX targeting via VariationAjaxChangeSubscriber.
 */
function commerce_variation_blocks_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if (!$entity instanceof ProductInterface) {
    return;
  }

  $variation = $entity->getDefaultVariation();
  if (!$variation) {
    return;
  }

  $view_builder = \Drupal::entityTypeManager()
    ->getViewBuilder('commerce_product_variation');

  $view_modes = \Drupal::service('entity_display.repository')
    ->getViewModes('commerce_product_variation');

  $skip = ['default', 'cart', 'card', 'summary'];
  $product_id = $entity->id();

  foreach ($view_modes as $view_mode_id => $view_mode_info) {
    if (in_array($view_mode_id, $skip)) {
      continue;
    }

    $field_name = 'variation_block__' . $view_mode_id;
    $rendered = $view_builder->view($variation, $view_mode_id);

    $build[$field_name] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['commerce-variation-block--' . $view_mode_id . '--' . $product_id],
      ],
      'content' => $rendered,
    ];
  }
}
